<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PinStats.Views.TaskbarWidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PinStats.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ex="using:WinUIEx"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PinStats Taskbar Widget"
    Closed="OnTaskbarWidgetWindowClosed"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <ex:TransparentTintBackdrop />
    </Window.SystemBackdrop>

    <controls:TaskbarWidgetControl x:Name="TaskbarWidgetContent" />
</Window>
