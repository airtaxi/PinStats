<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PinStats.Controls.TaskbarWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="48"
    d:DesignWidth="300"
    CornerRadius="4"
    mc:Ignorable="d">

    <!--  Item widths are configured from TaskbarWidgetSettings in code-behind.  -->
    <Button
        x:Name="RootButton"
        Margin="4"
        Padding="2"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Background="Transparent"
        BorderBrush="Transparent"
        Click="OnRootButtonClicked">
        <StackPanel
            x:Name="ItemsPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Orientation="Horizontal">

            <!--  CPU usage  -->
            <Grid x:Name="ItemCpuUsage">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <ProgressRing
                        x:Name="ProgressRingCpuUsage"
                        Width="18"
                        Height="18"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        IsIndeterminate="False"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="TextBlockCpuUsage"
                        VerticalAlignment="Center"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Text="0%" />
                </StackPanel>
            </Grid>

            <!--  GPU usage  -->
            <Grid x:Name="ItemGpuUsage">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <ProgressRing
                        x:Name="ProgressRingGpuUsage"
                        Width="18"
                        Height="18"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        IsIndeterminate="False"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="TextBlockGpuUsage"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="0%" />
                </StackPanel>
            </Grid>

            <!--  Memory usage  -->
            <Grid x:Name="ItemMemoryUsage">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <ProgressRing
                        x:Name="ProgressRingMemoryUsage"
                        Width="18"
                        Height="18"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        IsIndeterminate="False"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="TextBlockMemoryUsage"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="0%" />
                </StackPanel>
            </Grid>

            <!--  Virtual memory usage  -->
            <Grid x:Name="ItemVirtualMemoryUsage">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <ProgressRing
                        x:Name="ProgressRingVirtualMemoryUsage"
                        Width="18"
                        Height="18"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        IsIndeterminate="False"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="TextBlockVirtualMemoryUsage"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="0%" />
                </StackPanel>
            </Grid>

            <!--  Network up/down speeds  -->
            <Grid x:Name="ItemNetworkSpeed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="10"
                            Glyph="&#xE74A;" />
                        <TextBlock
                            x:Name="TextBlockNetworkUploadSpeed"
                            Width="46"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Text="0 KB/s" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="10"
                            Glyph="&#xE74B;" />
                        <TextBlock
                            x:Name="TextBlockNetworkDownloadSpeed"
                            Width="46"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Text="0 KB/s" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!--  Storage read/write speeds  -->
            <Grid x:Name="ItemStorageSpeed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="10"
                            Glyph="&#xE896;" />
                        <TextBlock
                            x:Name="TextBlockStorageReadSpeed"
                            Width="46"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Text="0 KB/s" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="10"
                            Glyph="&#xE898;" />
                        <TextBlock
                            x:Name="TextBlockStorageWriteSpeed"
                            Width="46"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Text="0 KB/s" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!--  Battery percentage  -->
            <Grid x:Name="ItemBatteryPercent">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <ProgressRing
                        x:Name="ProgressRingBatteryPercent"
                        Width="18"
                        Height="18"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        IsIndeterminate="False"
                        Maximum="100"
                        Minimum="0" />
                    <TextBlock
                        x:Name="TextBlockBatteryPercent"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Text="0%" />
                </StackPanel>
            </Grid>

            <!--  Battery charge/discharge power  -->
            <Grid x:Name="ItemBatteryPower">
                <TextBlock
                    x:Name="TextBlockBatteryPower"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Text="+0.0 W" />
            </Grid>
        </StackPanel>
    </Button>
</UserControl>
